FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/root

# 기본 도구 설치
RUN apt-get update && apt-get install -y \
    curl wget git unzip zip sudo \
    build-essential software-properties-common \
    && rm -rf /var/lib/apt/lists/*

# === "꼬인 환경" 시뮬레이션 ===

# 1. 다중 Python 버전 (충돌)
RUN apt-get update && apt-get install -y python3.10 python3.11 \
    && ln -sf /usr/bin/python3.10 /usr/local/bin/python3 \
    && ln -sf /usr/bin/python3.11 /usr/bin/python3 \
    && rm -rf /var/lib/apt/lists/*

# 2. 깨진 심볼릭 링크
RUN ln -s /nonexistent/path/java /usr/local/bin/java-broken \
    && ln -s /nonexistent/path/gradle /usr/local/bin/gradle-broken

# 3. 잘못된 JAVA_HOME 환경변수
RUN echo 'export JAVA_HOME=/usr/lib/jvm/java-11-fake' >> /root/.bashrc \
    && echo 'export PATH=$JAVA_HOME/bin:$PATH' >> /root/.bashrc

# 4. Node.js 구버전 설치 (충돌용)
RUN curl -fsSL https://deb.nodesource.com/setup_18.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# 5. PATH에 중복 항목
RUN echo 'export PATH=/usr/local/bin:/usr/bin:/usr/local/bin:/opt/bin:$PATH' >> /root/.bashrc

# === OpenClaw 설치 ===

# nvm + Node 22 설치
RUN curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
ENV NVM_DIR=/root/.nvm
RUN . "$NVM_DIR/nvm.sh" && nvm install 22 && nvm alias default 22

# OpenClaw 설치
RUN . "$NVM_DIR/nvm.sh" && npm install -g openclaw@latest

# 작업 디렉토리
WORKDIR /root

# 테스트 시작점
CMD ["/bin/bash"]
